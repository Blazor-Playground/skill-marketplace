{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "marketplace.schema.json",
  "$comment": "Based on https://docs.github.com/en/copilot/reference/cli-plugin-reference#marketplacejson",
  "title": "Copilot CLI Marketplace Configuration",
  "description": "Schema for marketplace.json files used by GitHub Copilot CLI plugin marketplaces",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "properties": {
    "$schema": { "type": "string" },
    "name": {
      "type": "string",
      "description": "Kebab-case marketplace name. Max 64 chars.",
      "maxLength": 64
    },
    "owner": {
      "type": "object",
      "description": "Marketplace owner info",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "Owner or organization name" },
        "email": { "type": "string", "format": "email", "description": "Contact email" }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional marketplace metadata",
      "properties": {
        "description": { "type": "string", "description": "Human-readable description" },
        "version": { "type": "string", "description": "Marketplace version" },
        "pluginRoot": { "type": "string", "description": "Default root directory for plugins" },
        "sourceCommit": { "type": "string", "description": "Source commit SHA (used by sync tools)" }
      }
    },
    "plugins": {
      "type": "array",
      "description": "List of plugin entries",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      }
    }
  },
  "$defs": {
    "stringOrStringArray": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "pluginEntry": {
      "type": "object",
      "required": ["name", "source"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Kebab-case plugin name. Max 64 chars.",
          "maxLength": 64
        },
        "source": {
          "description": "Where to fetch the plugin (relative path, GitHub owner/repo, or URL)",
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "description": { "type": "string", "description": "Plugin description. Max 1024 chars.", "maxLength": 1024 },
        "version": { "type": "string", "description": "Plugin version" },
        "author": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "url": { "type": "string" }
          }
        },
        "homepage": { "type": "string", "description": "Plugin homepage URL" },
        "repository": { "type": "string", "description": "Source repository URL" },
        "license": { "type": "string", "description": "License identifier (e.g., MIT)" },
        "keywords": { "type": "array", "items": { "type": "string" }, "description": "Search keywords" },
        "category": { "type": "string", "description": "Plugin category" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Additional tags" },
        "skills": { "$ref": "#/$defs/stringOrStringArray", "description": "Path(s) to skill directories" },
        "agents": { "$ref": "#/$defs/stringOrStringArray", "description": "Path(s) to agent directories" },
        "commands": { "$ref": "#/$defs/stringOrStringArray", "description": "Path(s) to command directories" },
        "hooks": {
          "description": "Path to hooks config file, or inline hooks object",
          "oneOf": [{ "type": "string" }, { "type": "object" }]
        },
        "mcpServers": {
          "description": "Path to MCP config file, or inline server definitions",
          "oneOf": [{ "type": "string" }, { "type": "object" }]
        },
        "lspServers": {
          "description": "Path to LSP config file, or inline server definitions",
          "oneOf": [{ "type": "string" }, { "type": "object" }]
        },
        "strict": {
          "type": "boolean",
          "description": "When true (default), full schema validation. When false, relaxed validation."
        }
      }
    }
  }
}
